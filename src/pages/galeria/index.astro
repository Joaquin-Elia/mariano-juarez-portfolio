---
import BackBtn from "../../components/BackBtn.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Galería - Mariano Juárez">
  <section class="gallery">
    <canvas></canvas>
  </section>
  <BackBtn className="absolute top-5 left-5"/>
</Layout>

<style>
  .gallery {
    position: relative;
    user-select: none;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    background-color: #fff;
  }
  .gallery canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* overflow: hidden; */
  }
</style>

<script>
  import "../../scripts/gallery.ts";
</script>
