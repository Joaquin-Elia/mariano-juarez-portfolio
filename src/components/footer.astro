---
const currentYear = new Date().getFullYear();
---

<footer
  class="absolute bottom-4 left-0 flex flex-col md:flex-row items-start md:items-end justify-between w-full px-3 lg:px-8 z-50 gap-4 md:gap-0 pointer-events-none user-select-none"
>
  <p
    class="max-w-xs font-space-mono-bold text-[10px] sm:text-xs pointer-events-auto text-justify"
  >
    <span class="bg-yellow text-black px-1 uppercase box-decoration-clone"
      >@Mariano Juarez. {currentYear}. All rights reserved. By using this site,
      you agree to our privacy policy and the processing of personal
      data.</span
    >
  </p>
  <ul
    class="flex flex-wrap gap-2 md:gap-4 font-space-mono-bold text-sm sm:text-base pointer-events-auto"
  >
    <li>
      <a
        href="https://www.linkedin.com/in/marianojuarez"
        class="inline-block bg-yellow text-black uppercase leading-none hover:blur-[1.5px] transition-all duration-300 box-decoration-clone"
        target="_blank"
        rel="noopener noreferrer"
      >
        Linkedin
      </a>
    </li>
    <li>
      <a
        href="https://www.instagram.com/marianodajuarez/"
        class="inline-block bg-yellow text-black uppercase leading-none hover:blur-[1.5px] transition-all duration-300 box-decoration-clone"
        target="_blank"
        rel="noopener noreferrer"
      >
        Instagram
      </a>
    </li>
  </ul>
</footer>
