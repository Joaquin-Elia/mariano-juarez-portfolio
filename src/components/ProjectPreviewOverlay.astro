---

---

<div
  id="project-preview-overlay"
  class="fixed inset-0 mt-10 pointer-events-none z-70 hidden lg:block overflow-hidden"
>
  <div
    id="project-preview-container"
    class="absolute aspect-auto opacity-0 scale-90 overflow-hidden origin-bottom"
  >
    <video
      id="project-preview-video"
      src=""
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"></video>
  </div>
</div>

<script>
  import gsap from "gsap";

  let mm: gsap.MatchMedia;

  const initPreview = () => {
    if (mm) mm.revert();
    mm = gsap.matchMedia();

    mm.add("(min-width: 1024px)", () => {
      const overlay = document.getElementById("project-preview-overlay");
      const container = document.getElementById("project-preview-container");
      const items = document.querySelectorAll(".project-item");

      if (!overlay || !container || items.length === 0) return;

      // Generar elementos de video para cada proyecto
      container.innerHTML = "";
      const videoMap = new Map();

      items.forEach((item) => {
        const videoSrc = item.getAttribute("data-video");
        const videoStyle = item.getAttribute("video-style") || "";
        const aspectRatio = item.getAttribute("data-aspect-ratio") || "";

        if (videoSrc) {
          const video = document.createElement("video");
          video.src = videoSrc;
          video.muted = true;
          video.loop = true;
          video.playsInline = true;
          video.preload = "auto";
          video.className = `absolute inset-0 w-full h-full object-cover opacity-0 preview-video`;

          if (videoStyle) {
            const classes = videoStyle
              .split(" ")
              .filter((c) => c.trim() !== "");
            if (classes.length) video.classList.add(...classes);
          }

          if (videoSrc.includes("res.cloudinary.com")) {
            video.poster = videoSrc
              .replace("/video/upload/", "/video/upload/f_auto,q_auto,w_20/")
              .replace(/\.[^/.]+$/, ".jpg");
          }

          if (aspectRatio) {
            video.style.aspectRatio = aspectRatio;
          }

          const handleMetadata = () => {
            if (video.videoWidth && video.videoHeight) {
              const ratio = `${video.videoWidth} / ${video.videoHeight}`;
              video.style.aspectRatio = ratio;
              // También actualizar el contenedor si este video es el que se está mostrando actualmente
              if (video.style.opacity === "1") {
                container.style.aspectRatio = ratio;
              }
            }
            video.removeEventListener("loadedmetadata", handleMetadata);
          };
          video.addEventListener("loadedmetadata", handleMetadata);

          const handleCanPlay = () => {
            video.classList.add("loaded");
            video.removeEventListener("canplay", handleCanPlay);
          };
          video.addEventListener("canplay", handleCanPlay);

          if (video.readyState >= 3) {
            video.classList.add("loaded");
          }

          container.appendChild(video);
          videoMap.set(item, video);
        }
      });

      let targetX = 0;
      let targetY = 0;
      let currentX = 0;
      let currentY = 0;
      let rafId: number | null = null;
      let isHovering = false;

      // Initial resting state
      gsap.set(container, {
        xPercent: -50,
        yPercent: 8,
        opacity: 0,
        scale: 0.9,
      });

      const updatePosition = () => {
        currentX += (targetX - currentX) * 0.15;
        currentY += (targetY - currentY) * 0.15;

        gsap.set(container, { x: currentX, y: currentY });

        if (isHovering) {
          rafId = requestAnimationFrame(updatePosition);
        } else {
          rafId = requestAnimationFrame(() => {
            gsap.set(container, { x: currentX, y: currentY });
            rafId = null;
          });
        }
      };

      const handleMouseMove = (e: MouseEvent) => {
        targetX = e.clientX;
        targetY = e.clientY;
      };

      const onMouseEnter = (e: Event) => {
        const target = e.currentTarget as HTMLElement;
        const video = videoMap.get(target);
        const videoStyle = target.getAttribute("video-style") || "";
        const aspectRatio = target.getAttribute("data-aspect-ratio") || "";
        if (!video) return;

        // Reset y aplicar estilos al contenedor (sin resetear opacidad ni usar transiciones CSS)
        container.className = "absolute overflow-hidden origin-bottom w-full";
        if (videoStyle) {
          container.classList.add(...videoStyle.split(" "));
        }

        // Sincronizar aspect ratio
        if (aspectRatio) {
          container.style.aspectRatio = aspectRatio;
          video.style.aspectRatio = aspectRatio;
        } else if (video.videoWidth) {
          const ratio = `${video.videoWidth} / ${video.videoHeight}`;
          container.style.aspectRatio = ratio;
          video.style.aspectRatio = ratio;
        }

        // Mostrar este video y pausar otros
        videoMap.forEach((v) => {
          if (v !== video) {
            gsap.set(v, { opacity: 0 });
            v.pause();
          }
        });

        gsap.set(video, { opacity: 1 });
        video.play().catch(() => {});

        isHovering = true;
        const mouseEvent = e as MouseEvent;

        targetX = mouseEvent.clientX;
        targetY = mouseEvent.clientY;

        if (currentX === 0 && currentY === 0) {
          currentX = targetX;
          currentY = targetY;
          gsap.set(container, { x: currentX, y: currentY });
        }

        document.addEventListener("mousemove", handleMouseMove);
        if (rafId === null) {
          rafId = requestAnimationFrame(updatePosition);
        }

        gsap.to(container, {
          opacity: 1,
          scale: 1,
          duration: 0.4,
          ease: "power2.out",
          overwrite: "auto",
        });
      };

      const onMouseLeave = () => {
        isHovering = false;

        gsap.to(container, {
          opacity: 0,
          scale: 0.9,
          duration: 0.3,
          ease: "power2.in",
          overwrite: "auto",
          onComplete: () => {
            if (!isHovering) {
              document.removeEventListener("mousemove", handleMouseMove);
              currentX = 0;
              currentY = 0;
              videoMap.forEach((v) => v.pause());
            }
          },
        });
      };

      items.forEach((item) => {
        item.addEventListener("mouseenter", onMouseEnter);
        item.addEventListener("mouseleave", onMouseLeave);
      });

      return () => {
        items.forEach((item) => {
          item.removeEventListener("mouseenter", onMouseEnter);
          item.removeEventListener("mouseleave", onMouseLeave);
        });
        document.removeEventListener("mousemove", handleMouseMove);
        if (rafId !== null) cancelAnimationFrame(rafId);
      };
    });
  };

  initPreview();
  // Safe cleanup and re-evaluation upon Astro view transition navigation
  document.addEventListener("astro:page-load", initPreview);
</script>

<style is:global>
  .preview-video {
    filter: blur(10rem);
    -webkit-filter: blur(10rem);
    transform: scale(1.05) translateZ(0);
    will-change: filter, transform;
    min-width: 20rem;
    transition:
      filter 0.5s ease-out,
      -webkit-filter 0.5s ease-out,
      transform 0.5s ease-out;
  }
  .preview-video.loaded {
    filter: blur(0);
    -webkit-filter: blur(0);
    transform: scale(1) translateZ(0);
  }
</style>
