---
import { cld } from "../utils/cloudinary";

interface Props {
  src: string;
  alt?: string;
  sizes?: string;
}

const {
  src,
  alt = "",
  sizes = "(max-width: 768px) 50vw, 1200px",
} = Astro.props;

// tamaños que va a poder elegir el navegador
const widths = [768, 1280, 1920];

// srcset dinámico
const srcset = widths
  .map((w) => `${cld(src, `f_auto,q_auto,w_${w}`)} ${w}w`)
  .join(", ");

// fallback
const fallback = cld(src, "f_auto,q_auto,w_800");

// placeholder blur
const placeholder = cld(src, "f_auto,q_auto,w_20");
---

<img
  src={fallback}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  loading="lazy"
  style={`background-image: url('${placeholder}')`}
  class="responsive-img aspect-auto"
/>

<style is:global>
  .responsive-img {
    width: 100%;
    height: auto;
    display: block;
    background-size: cover;
    background-position: center;
    aspect-ratio: 1/1;
    filter: blur(1rem);
    -webkit-filter: blur(1rem);
    transform: translate3d(0, 0, 0) scale(1.05);
    opacity: 0.9;
    transition:
      filter 0.6s ease,
      -webkit-filter 0.6s ease,
      transform 0.6s ease,
      opacity 0.6s ease;
  }

  .responsive-img.loaded {
    aspect-ratio: auto;
    filter: blur(0);
    -webkit-filter: blur(0);
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 1;
  }
</style>

<script>
  function setupResponsiveImages() {
    const images = document.querySelectorAll(".responsive-img");

    images.forEach((el) => {
      const img = el as HTMLImageElement;
      let isLoaded = false;
      let checkInterval: number;

      const markAsLoaded = () => {
        if (isLoaded) return;
        isLoaded = true;
        clearInterval(checkInterval);
        img.classList.add("loaded");
        setTimeout(() => {
          img.style.backgroundImage = "none";
        }, 600);
      };

      const markAsError = () => {
        clearInterval(checkInterval);
        img.classList.add("loaded");
        img.style.filter = "none";
        img.style.webkitFilter = "none";
      };

      if (img.complete && img.naturalWidth > 0) {
        markAsLoaded();
      } else {
        img.addEventListener("load", markAsLoaded, { once: true });
        img.addEventListener("error", markAsError, { once: true });

        if ("decode" in img) {
          img.decode().then(markAsLoaded).catch(() => {});
        }

        // Safari iOS 16 Fallback: Poll for completion if events are missed
        checkInterval = setInterval(() => {
          if (img.complete && img.naturalWidth > 0) {
            markAsLoaded();
          }
        }, 300) as unknown as number;
        
        // Stop polling after 15 seconds to save resources
        setTimeout(() => clearInterval(checkInterval), 15000);
      }
    });
  }

  // Ejecutar en cada carga de página
  document.addEventListener("astro:page-load", () => {
    requestAnimationFrame(setupResponsiveImages);
  });
</script>
