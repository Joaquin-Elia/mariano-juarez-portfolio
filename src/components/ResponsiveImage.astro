---
import { cld } from "../utils/cloudinary";

interface Props {
  src: string;
  alt?: string;
  sizes?: string;
}

const {
  src,
  alt = "",
  sizes = "(max-width: 768px) 50vw, 1200px",
} = Astro.props;

// tamaños que va a poder elegir el navegador
const widths = [768, 1280, 1920];

// srcset dinámico
const srcset = widths
  .map((w) => `${cld(src, `f_auto,q_auto,w_${w}`)} ${w}w`)
  .join(", ");

// fallback
const fallback = cld(src, "f_auto,q_auto,w_800");

// placeholder blur
const placeholder = cld(src, "f_auto,q_auto,w_20");
---

<img
  src={fallback}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  loading="lazy"
  decoding="async"
  style={`background-image: url('${placeholder}')`}
  class="responsive-img aspect-auto"
/>

<style is:global>
  .responsive-img {
    width: 100%;
    height: auto;
    display: block;
    background-size: cover;
    background-position: center;
    aspect-ratio: 1/1;
    filter: blur(1rem);
    -webkit-filter: blur(1rem);
    transform: scale(1.05) translateZ(0);
    will-change: filter, transform;
    opacity: 0.9;
    transition:
      filter 0.6s ease,
      -webkit-filter 0.6s ease,
      transform 0.6s ease,
      opacity 0.6s ease;
  }

  .responsive-img.loaded {
    aspect-ratio: auto;
    filter: blur(0);
    -webkit-filter: blur(0);
    transform: scale(1) translateZ(0);
    opacity: 1;
  }
</style>

<script>
  function setupResponsiveImages() {
    const images = document.querySelectorAll(".responsive-img");

    images.forEach((el) => {
      const img = el as HTMLImageElement;
      let isLoaded = false;

      const markAsLoaded = () => {
        if (isLoaded) return;
        isLoaded = true;
        img.classList.add("loaded");
        // Quitar placeholder después de la transición para evitar parpadeos
        setTimeout(() => {
          img.style.backgroundImage = "none";
        }, 600);
      };

      const markAsError = () => {
        img.classList.add("loaded");
        img.style.filter = "none";
        img.style.webkitFilter = "none";
      };

      // Check inmediato
      if (img.complete && img.naturalWidth > 0) {
        markAsLoaded();
      } else {
        // Listener estándar
        img.addEventListener("load", markAsLoaded, { once: true });
        img.addEventListener("error", markAsError, { once: true });

        // Safari / Modern browsers fix: decode()
        if ("decode" in img) {
          img
            .decode()
            .then(() => {
              markAsLoaded();
            })
            .catch(() => {
              // Si falla el decode pero la imagen termina cargando igual, el listener 'load' se encarga
            });
        }
      }
    });
  }

  // Ejecutar en cada carga de página
  document.addEventListener("astro:page-load", () => {
    requestAnimationFrame(setupResponsiveImages);
  });
</script>
